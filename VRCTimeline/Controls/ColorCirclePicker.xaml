<UserControl x:Class="VRCTimeline.Controls.ColorCirclePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Grid Width="200" Height="200" Cursor="Cross">
                <Image x:Name="WheelImage" Stretch="None"
                       MouseLeftButtonDown="OnWheelMouseDown"
                       MouseMove="OnWheelMouseMove"
                       MouseLeftButtonUp="OnWheelMouseUp" />
                <Canvas IsHitTestVisible="False">
                    <Ellipse x:Name="Selector" Width="14" Height="14"
                             Stroke="White" StrokeThickness="2"
                             Canvas.Left="93" Canvas.Top="93">
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="3" Color="Black" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>
            </Grid>
            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="明るさ" FontSize="11" Opacity="0.6" Margin="0,0,0,4"
                           HorizontalAlignment="Center" />
                <Slider x:Name="BrightnessSlider" Orientation="Vertical"
                        Height="170"
                        Minimum="0.15" Maximum="1" Value="1"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        ValueChanged="OnBrightnessChanged" />
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Rectangle x:Name="PreviewRect" Width="32" Height="32"
                       RadiusX="4" RadiusY="4"
                       Stroke="Gray" StrokeThickness="1" />
            <TextBox x:Name="HexInput" Width="100" Margin="8,0,0,0"
                     materialDesign:HintAssist.Hint="#RRGGBB"
                     VerticalAlignment="Center"
                     TextChanged="OnHexInputChanged" />
        </StackPanel>
    </StackPanel>
</UserControl>
