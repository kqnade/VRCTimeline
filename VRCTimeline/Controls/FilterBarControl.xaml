<UserControl x:Class="VRCTimeline.Controls.FilterBarControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <Style x:Key="DarkCalendarDayButton" TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Grid>
                            <Ellipse x:Name="Bg" Fill="Transparent" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#79A1CB" />
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="Bg" Property="Stroke" Value="#79A1CB" />
                                <Setter TargetName="Bg" Property="StrokeThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#3379A1CB" />
                            </Trigger>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="Foreground" Value="#55FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#77FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCalendarButton" TargetType="CalendarButton">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinWidth" Value="60" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Grid>
                            <Rectangle x:Name="Bg" Fill="Transparent" RadiusX="12" RadiusY="12" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#3379A1CB" />
                            </Trigger>
                            <Trigger Property="HasSelectedDays" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#79A1CB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCalendar" TargetType="Calendar">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource DarkCalendarDayButton}" />
            <Setter Property="CalendarButtonStyle" Value="{StaticResource DarkCalendarButton}" />
        </Style>
    </UserControl.Resources>

    <materialDesign:Card Padding="16" Margin="0,0,0,12">
        <WrapPanel>
            <DatePicker SelectedDate="{Binding FilterDateFrom, ElementName=Root}"
                        materialDesign:HintAssist.Hint="{DynamicResource Filter_StartDate}"
                        CalendarStyle="{StaticResource DarkCalendar}"
                        Width="150" Margin="0,0,8,4"
                        Loaded="DatePicker_Loaded" />
            <TextBlock Text="～" VerticalAlignment="Center" Margin="0,0,8,4"
                       FontSize="16" />
            <DatePicker SelectedDate="{Binding FilterDateTo, ElementName=Root}"
                        materialDesign:HintAssist.Hint="{DynamicResource Filter_EndDate}"
                        CalendarStyle="{StaticResource DarkCalendar}"
                        Width="150" Margin="0,0,20,4"
                        Loaded="DatePicker_Loaded" />

            <TextBox Text="{Binding PlayerFilterText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="{DynamicResource Filter_PlayerName}"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     Width="220" Margin="0,0,12,4"
                     Visibility="{Binding ShowPlayerFilter, ElementName=Root, Converter={StaticResource BoolToVis}}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand, ElementName=Root}" />
                </TextBox.InputBindings>
            </TextBox>

            <TextBox Text="{Binding WorldFilterText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="{DynamicResource Filter_WorldName}"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     Width="220" Margin="0,0,12,4"
                     Visibility="{Binding ShowWorldFilter, ElementName=Root, Converter={StaticResource BoolToVis}}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand, ElementName=Root}" />
                </TextBox.InputBindings>
            </TextBox>

            <TextBox Text="{Binding VideoTitleFilterText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="{DynamicResource Filter_VideoTitle}"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     Width="220" Margin="0,0,12,4"
                     Visibility="{Binding ShowVideoTitleFilter, ElementName=Root, Converter={StaticResource BoolToVis}}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand, ElementName=Root}" />
                </TextBox.InputBindings>
            </TextBox>

            <ComboBox ItemsSource="{Binding TypeFilterItems, ElementName=Root}"
                      SelectedItem="{Binding SelectedTypeFilter, ElementName=Root}"
                      materialDesign:HintAssist.Hint="{DynamicResource Filter_Type}"
                      Width="140" Margin="0,0,12,4"
                      Visibility="{Binding ShowTypeFilter, ElementName=Root, Converter={StaticResource BoolToVis}}" />

            <Button Content="{DynamicResource Filter_Search}" Command="{Binding SearchCommand, ElementName=Root}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,0,4" />

            <ProgressBar IsIndeterminate="True" Width="100" Margin="12,0,0,4">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Hidden" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowProgressBar, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </WrapPanel>
    </materialDesign:Card>
</UserControl>
