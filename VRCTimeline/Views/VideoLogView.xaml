<UserControl x:Class="VRCTimeline.Views.VideoLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:VRCTimeline.Controls"
             Loaded="UserControl_Loaded">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <controls:FilterBarControl Grid.Row="0"
            FilterDateFrom="{Binding FilterDateFrom}"
            FilterDateTo="{Binding FilterDateTo}"
            ShowPlayerFilter="False"
            WorldFilterText="{Binding SearchWorldName}"
            ShowVideoTitleFilter="True"
            VideoTitleFilterText="{Binding SearchVideoTitle}"
            SearchCommand="{Binding LoadVideosCommand}" />

        <!-- Video List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Videos}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Padding="14" Margin="0,0,0,8"
                                              materialDesign:ElevationAssist.Elevation="Dp2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Thumbnail -->
                                <Border Grid.Column="0" Width="120" Height="68"
                                        CornerRadius="4" Background="#2A2A2A"
                                        ClipToBounds="True"
                                        Margin="0,0,14,0"
                                        Visibility="{Binding IsYouTube, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToThumb}}"
                                           Stretch="UniformToFill"
                                           VerticalAlignment="Center" />
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Medium"
                                               FontSize="14" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Title, Converter={StaticResource NullToVis}}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Cursor="Hand" TextDecorations="Underline"
                                               Foreground="#4FC3F7" FontSize="12"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Text>
                                            <Binding Path="Url" />
                                        </TextBlock.Text>
                                        <TextBlock.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenUrlCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding Url}" />
                                        </TextBlock.InputBindings>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding DetectedAtDisplay}"
                                                   FontSize="11" Opacity="0.5" />
                                        <TextBlock Text="{Binding WorldName}"
                                                   FontSize="11" Opacity="0.5" Margin="16,0,0,0"
                                                   Visibility="{Binding WorldName, Converter={StaticResource NullToVis}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
