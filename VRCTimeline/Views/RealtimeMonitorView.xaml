<UserControl x:Class="VRCTimeline.Views.RealtimeMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status Card -->
        <materialDesign:Card Grid.Row="0" Padding="20" Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel>
                <TextBlock Text="{DynamicResource Realtime_CurrentWorld}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.6" />
                <TextBlock Text="{Binding CurrentWorldName}"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           Margin="0,4,0,8" TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AccountGroup" VerticalAlignment="Center"
                                              Margin="0,0,6,0" />
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{Binding PlayerCount}" />
                        <Run Text="{DynamicResource Str_PlayerUnit}" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Player List -->
            <materialDesign:Card Grid.Column="0" Padding="16"
                                  materialDesign:ElevationAssist.Elevation="Dp1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Realtime_JoinedPlayers}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CurrentPlayers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <materialDesign:PackIcon Kind="Account" Margin="0,0,8,0"
                                                                  VerticalAlignment="Center" Opacity="0.7" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </materialDesign:Card>

            <!-- Log Stream -->
            <materialDesign:Card Grid.Column="2" Padding="16"
                                  materialDesign:ElevationAssist.Elevation="Dp1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Realtime_Log}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,3">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Timestamp, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                   Opacity="0.5" Margin="0,0,10,0"
                                                   FontFamily="Consolas" FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                                                 Margin="0,0,10,0" VerticalAlignment="Center"
                                                 Fill="{Binding Type, Converter={StaticResource LogTypeColor}}" />
                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
