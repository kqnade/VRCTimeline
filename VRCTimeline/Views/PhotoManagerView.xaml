<UserControl x:Class="VRCTimeline.Views.PhotoManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:VRCTimeline.Controls"
             Loaded="UserControl_Loaded">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <controls:FilterBarControl Grid.Row="0"
            FilterDateFrom="{Binding FilterDateFrom}"
            FilterDateTo="{Binding FilterDateTo}"
            PlayerFilterText="{Binding PlayerFilter}"
            WorldFilterText="{Binding WorldFilter}"
            SearchCommand="{Binding LoadPhotosCommand}"
            ShowProgressBar="{Binding IsLoading}" />

        <!-- Status -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusText}" Opacity="0.6" Margin="0,0,16,0" />
            <materialDesign:PackIcon Kind="ClockTimeFourOutline" Width="14" Height="14"
                                      VerticalAlignment="Center" Margin="0,0,5,0"
                                      Opacity="0.5" />
            <TextBlock Text="{Binding DateRangeText}" Opacity="0.5" FontSize="12"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Photo Detail Panel (always visible) -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,12"
                              materialDesign:ElevationAssist.Elevation="Dp3">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Vertical" VerticalAlignment="Top"
                            Margin="24,0,0,0">
                    <Button Content="{DynamicResource Photo_ShowActivity}" Command="{Binding ShowActivityForVisitCommand}"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            IsEnabled="{Binding IsPhotoSelected}"
                            Margin="0,0,0,6" />
                    <Button Content="{DynamicResource Photo_OpenPhoto}" Command="{Binding OpenSelectedPhotoCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            IsEnabled="{Binding IsPhotoSelected}"
                            Margin="0,0,0,6" />
                    <Button Content="{DynamicResource Photo_OpenFolder}" Command="{Binding OpenPhotoFolderCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            IsEnabled="{Binding IsPhotoSelected}" />
                </StackPanel>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Photo_JoinedPlayers}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0"
                                    Visibility="{Binding HasPlayerContext, Converter={StaticResource BoolToVis}}">
                            <materialDesign:PackIcon Kind="Earth" Width="18" Height="18"
                                                      VerticalAlignment="Center" Margin="0,0,8,0"
                                                      Opacity="0.7" />
                            <TextBlock Text="{Binding SelectedPhotoWorldName}" VerticalAlignment="Center"
                                       FontWeight="Bold" FontSize="13" />
                            <materialDesign:PackIcon Kind="ClockTimeFourOutline" Width="16" Height="16"
                                                      VerticalAlignment="Center" Margin="20,0,6,0"
                                                      Opacity="0.6" />
                            <TextBlock Text="{Binding SelectedPhotoTimeRange}" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.7" />
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" x:Name="PlayerScrollViewer" Height="75"
                                  VerticalAlignment="Top"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SelectedPhotoPlayers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Padding="10,6" Margin="4" Cursor="Hand"
                                                          materialDesign:ElevationAssist.Elevation="Dp1">
                                        <materialDesign:Card.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SearchByPlayerCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding DisplayName}" />
                                        </materialDesign:Card.InputBindings>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding TimeRange}" FontSize="11"
                                                       Opacity="0.6" />
                                        </StackPanel>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Thumb Grid.Row="2" x:Name="PlayerResizeThumb" Height="6" Cursor="SizeNS"
                           DragDelta="PlayerResizeThumb_DragDelta"
                           Opacity="0.4">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Grid Background="Transparent">
                                    <Border Height="2" Width="40"
                                            Background="{DynamicResource MaterialDesignBody}"
                                            CornerRadius="1"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Opacity="0.4" />
                                </Grid>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </DockPanel>
        </materialDesign:Card>

        <!-- No Photos Message -->
        <TextBlock Grid.Row="3" Text="{DynamicResource Photo_NoPhotos}"
                   Visibility="{Binding HasNoPhotos, Converter={StaticResource BoolToVis}}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Opacity="0.5" />

        <!-- Photo Gallery (grouped) -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="PhotoScrollViewer_PreviewMouseWheel"
                      Visibility="{Binding HasNoPhotos, Converter={StaticResource InverseBoolToVis}}">
            <ItemsControl ItemsSource="{Binding PhotoGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <!-- Group Header -->
                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                    CornerRadius="4" Padding="12,6" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Earth" Width="18" Height="18"
                                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                                              Opacity="0.7" />
                                    <TextBlock Text="{Binding HeaderDisplay}" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                    <materialDesign:PackIcon Kind="ClockTimeFourOutline" Width="15" Height="15"
                                                              VerticalAlignment="Center" Margin="20,0,6,0"
                                                              Opacity="0.5" />
                                    <TextBlock Text="{Binding HeaderTimeRange}" FontSize="12"
                                               VerticalAlignment="Center" Opacity="0.6" />
                                </StackPanel>
                            </Border>

                            <!-- Photos in Group -->
                            <ItemsControl ItemsSource="{Binding Photos}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Width="210" Margin="6"
                                                             materialDesign:ElevationAssist.Elevation="Dp2"
                                                             Cursor="Hand">
                                            <materialDesign:Card.Style>
                                                <Style TargetType="materialDesign:Card">
                                                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="BorderBrush" Value="Transparent" /> <Setter Property="Opacity" Value="0.95" /> <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualityMulti}">
                                                                    <Binding />
                                                                    <Binding Path="DataContext.SelectedPhoto"
                                                                             RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp8" />
                                                            <Setter Property="Opacity" Value="1" /> <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueLightBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:Card.Style>
                                            <materialDesign:Card.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SelectPhotoCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}" />
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.OpenPhotoFileCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}" />
                                            </materialDesign:Card.InputBindings>
                                            <StackPanel>
                                                <Border Height="150" Background="#2A2A2A">
                                                    <Image Source="{Binding FilePath, Converter={StaticResource PathToThumb}, IsAsync=True}"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <StackPanel Margin="10,6,10,8">
                                                    <TextBlock Text="{Binding TakenAtDisplay}"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
