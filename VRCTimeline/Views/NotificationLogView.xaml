<UserControl x:Class="VRCTimeline.Views.NotificationLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:VRCTimeline.Controls"
             Loaded="UserControl_Loaded">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <controls:FilterBarControl Grid.Row="0"
            FilterDateFrom="{Binding FilterDateFrom}"
            FilterDateTo="{Binding FilterDateTo}"
            PlayerFilterText="{Binding SearchPlayerName}"
            ShowWorldFilter="False"
            ShowTypeFilter="True"
            TypeFilterItems="{Binding TypeFilters}"
            SelectedTypeFilter="{Binding SelectedTypeFilter}"
            SearchCommand="{Binding LoadNotificationsCommand}" />

        <!-- Notification List -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Notifications}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True"
                  materialDesign:DataGridAssist.CellPadding="12 8"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
                  BorderThickness="0"
                  Background="Transparent"
                  RowHeight="NaN">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Focusable" Value="False" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                    <Setter Property="Cursor" Value="Hand" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="42" MinWidth="42">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:PackIcon Kind="{Binding TypeIcon}" Width="20" Height="20"
                                                      VerticalAlignment="Center" Opacity="0.7" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource Col_DateTime}"
                    Binding="{Binding ReceivedAtDisplay}" Width="200" MinWidth="175">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{DynamicResource Col_Type}"
                    Binding="{Binding NotificationType}" Width="120" MinWidth="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="{DynamicResource Col_Sender}" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                    CornerRadius="4" Padding="8,4" Margin="2"
                                    Cursor="Hand" HorizontalAlignment="Left">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SearchByPlayerCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding SenderName}" />
                                </Border.InputBindings>
                                <TextBlock Text="{Binding SenderName}" FontSize="13" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
