<UserControl x:Class="VRCTimeline.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:VRCTimeline.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left">

            <!-- Directories -->
            <TextBlock Text="{DynamicResource Settings_DirectorySettings}"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,12" />
            <materialDesign:Card Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_VRChatLogFolder}" Margin="0,0,0,4"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6" />
                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right" Content="{DynamicResource Settings_Browse}"
                                Command="{Binding BrowseLogDirectoryCommand}"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                Margin="8,0,0,0" />
                        <TextBox Text="{Binding LogDirectory}" IsReadOnly="True" />
                    </DockPanel>

                    <TextBlock Text="{DynamicResource Settings_PhotoFolder}" Margin="0,0,0,4"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="{DynamicResource Settings_Browse}"
                                Command="{Binding BrowsePhotoDirectoryCommand}"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                Margin="8,0,0,0" />
                        <TextBox Text="{Binding PhotoDirectory}" IsReadOnly="True" />
                    </DockPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Appearance -->
            <TextBlock Text="{DynamicResource Settings_AppearanceSettings}"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,12" />
            <materialDesign:Card Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsDarkMode}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        <TextBlock Text="{DynamicResource Settings_DarkMode}" VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Accent Color (collapsible) -->
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="{DynamicResource Settings_Change}"
                                Command="{Binding ToggleAccentPickerCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Settings_AccentColor}" VerticalAlignment="Center" Width="80"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6" />
                            <Border Width="24" Height="24" Margin="12,0,0,0" CornerRadius="4"
                                    Background="{Binding AccentColorHex, Converter={StaticResource HexToBrush}}" />
                        </StackPanel>
                    </DockPanel>
                    <controls:ColorCirclePicker SelectedHex="{Binding AccentColorHex}" Margin="0,0,0,12"
                                                 Visibility="{Binding IsAccentPickerOpen, Converter={StaticResource BoolToVis}}" />

                    <!-- Button Text Color (collapsible) -->
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="{DynamicResource Settings_Change}"
                                Command="{Binding ToggleButtonTextPickerCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Settings_ButtonTextColor}" VerticalAlignment="Center" Width="80"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6" />
                            <Border Width="24" Height="24" Margin="12,0,0,0" CornerRadius="4"
                                    Background="{Binding ButtonTextColorHex, Converter={StaticResource HexToBrush}}" />
                        </StackPanel>
                    </DockPanel>
                    <controls:ColorCirclePicker SelectedHex="{Binding ButtonTextColorHex}" Margin="0,0,0,8"
                                                 Visibility="{Binding IsButtonTextPickerOpen, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </materialDesign:Card>

            <!-- App Settings -->
            <TextBlock Text="{DynamicResource Settings_AppSettings}"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,12" />
            <materialDesign:Card Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding AutoDetectVRChat}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        <TextBlock Text="{DynamicResource Settings_ShowWindowOnVRChatDetected}" VerticalAlignment="Center" />
                    </DockPanel>

                    <DockPanel Margin="0,0,0,16">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding LaunchOnStartup}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        <TextBlock Text="{DynamicResource Settings_LaunchOnStartup}" VerticalAlignment="Center" />
                    </DockPanel>

                    <DockPanel>
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding MinimizeOnStartup}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        <TextBlock Text="{DynamicResource Settings_MinimizeOnStartup}" VerticalAlignment="Center" />
                    </DockPanel>

                </StackPanel>
            </materialDesign:Card>

            <!-- Language Settings -->
            <TextBlock Text="{DynamicResource Settings_LanguageSettings}"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,12" />
            <materialDesign:Card Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="200"
                              HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Data Management -->
            <TextBlock Text="{DynamicResource Settings_DataManagement}"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,12" />
            <materialDesign:Card Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Import from VRChatActivityLogViewer -->
                    <StackPanel Visibility="{Binding ShowImportSection, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Settings_ImportTitle}" Margin="0,0,0,8"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                        <TextBlock Text="{DynamicResource Settings_ImportDescription}"
                                   Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="{DynamicResource Settings_ImportButton}"
                                    Command="{Binding ImportActivityLogCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Margin="0,0,16,0" />
                            <TextBlock Text="{Binding ImportStatus}" VerticalAlignment="Center"
                                       Opacity="0.6" />
                            <ProgressBar IsIndeterminate="True" Width="100" Margin="16,0,0,0"
                                         Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <Separator Margin="0,0,0,16" />
                    </StackPanel>

                    <!-- Thumbnail Cache -->
                    <TextBlock Text="{DynamicResource Settings_ThumbnailCache}" Margin="0,0,0,8"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                    <TextBlock Text="{DynamicResource Settings_ThumbnailCacheDescription}"
                               Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,12"
                               Style="{StaticResource MaterialDesignBody2TextBlock}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <Button Content="{DynamicResource Settings_ClearCache}"
                                Command="{Binding ClearThumbnailCacheCommand}"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}" />
                        <Button Content="{DynamicResource Settings_OpenFolder}"
                                Command="{Binding OpenThumbnailCacheFolderCommand}"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                Margin="8,0,0,0" />
                    </StackPanel>

                    <Separator Margin="0,0,0,16" />

                    <!-- PC Migration -->
                    <TextBlock Text="{DynamicResource Settings_PCMigration}" Margin="0,0,0,8"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                    <TextBlock Text="{DynamicResource Settings_PCMigrationDescription}"
                               Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,12"
                               Style="{StaticResource MaterialDesignBody2TextBlock}" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{DynamicResource Settings_OpenFolder}" Command="{Binding OpenDataFolderCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
            <TextBlock Text="VRC Timeline   v1.1.2"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Opacity="0.4" HorizontalAlignment="Right" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
